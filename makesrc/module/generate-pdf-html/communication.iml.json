{
    "url": "/generate-pdf",
    "method": "POST",
    "headers": {
        "Content-Type": "application/json",
        "Accept": "application/pdf"
    },
    "body": {
        "type": "html",
        "title": "{{parameters.title}}",
        "data": {
            "html": "{{parameters.html}}",
            "css": "{{parameters.css}}"
        },
        "page": {
            "width": "{{parameters.pageWidth}}",
            "height": "{{parameters.pageHeight}}",
            "marginTop": "{{parameters.marginTop}}",
            "marginBottom": "{{parameters.marginBottom}}",
            "marginLeft": "{{parameters.marginLeft}}",
            "marginRight": "{{parameters.marginRight}}"
        }
    },
    "response": {
        "type": {
            "200": "binary",
            "*": "json"
        },
        "output": {
            "file": "{{body}}",
            "fileName": "{{if(parameters.title; parameters.title + '.pdf'; 'generated.pdf')}}",
            "contentType": "application/pdf",
            "title": "{{parameters.title}}",
            "generatedAt": "{{now}}"
        },
        "error": {
            "message": "{{if(body.name === 'ValidationError'; 'Validation Error: ' + body.fields[0].message; if(body.message; body.message; 'Failed to generate PDF'))}}"
        }
    }
}
